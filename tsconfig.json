{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": ".",
	"skipLibCheck": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": [
    "credentials/**/*.ts",
    "nodes/**/*.ts"
  ]
}
